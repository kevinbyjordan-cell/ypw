---
import Icon from './Icon.astro';

// Reusable Tailwind class strings for inputs (keeps markup readable).
const field =
  'w-full rounded-xl border border-brand-200 bg-white px-4 py-3 text-base text-ink placeholder:text-slate-400 transition-colors focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-200';
const labelCls = 'block text-sm font-semibold text-ink';

const pages = ['Home', 'About', 'Services', 'Testimonials', 'Gallery', 'Blog', 'Contact', 'FAQ'];
---
<section id="brief" class="relative overflow-hidden bg-gradient-to-b from-ink to-ink-2 py-20 sm:py-28">
  <div class="absolute inset-0 bg-grid opacity-50" aria-hidden="true"></div>
  <div class="pointer-events-none absolute left-1/2 top-0 h-72 w-[36rem] -translate-x-1/2 rounded-full bg-brand-500/20 blur-[120px]" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-3xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center reveal">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-sm font-medium text-brand-100">
        <Icon name="clipboard-list" class="h-4 w-4 text-cyan-glow" />
        Takes about 2 minutes
      </span>
      <h2 class="mt-5 font-display text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
        Fill out the brief in 2 minutes
      </h2>
      <p class="mt-4 text-lg text-slate-300">
        Tell us about your business and we'll send your free website preview within 48 hours.
        No payment, no commitment.
      </p>
    </div>

    <!-- Success message (shown after a successful submit) -->
    <div
      id="form-success"
      role="status"
      class="mt-10 hidden rounded-2xl border border-green-200 bg-green-50 p-8 text-center"
    >
      <span class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-green-100 text-green-600">
        <Icon name="check" class="h-7 w-7" />
      </span>
      <h3 class="mt-4 text-xl font-semibold text-ink">Thanks! You'll get your preview within 48h</h3>
      <p class="mt-2 text-muted">
        We've received your brief and will reach out by email with your free preview link. Keep an eye on your inbox.
      </p>
    </div>

    <form
      id="brief-form"
      class="mt-10 space-y-10 rounded-3xl border border-brand-100 bg-white p-6 shadow-card sm:p-9 reveal"
      action="[FORMSPREE_ENDPOINT]"
      method="POST"
      novalidate
    >
      <!-- Honeypot anti-spam field: hidden from humans, bots fill it in. -->
      <div class="absolute left-[-9999px]" aria-hidden="true">
        <label>Leave this field empty
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
        </label>
      </div>

      <!-- Group: Your Information -->
      <fieldset class="space-y-5">
        <legend class="font-display text-lg font-semibold text-ink">Your information</legend>
        <div>
          <label class={labelCls} for="fullName">Full name <span class="text-cta-500">*</span></label>
          <input id="fullName" name="Full name" type="text" required class={`mt-2 ${field}`} placeholder="Jane Smith" />
          <p class="error-msg mt-1 hidden text-sm text-red-600"></p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class={labelCls} for="company">Company / project name</label>
            <input id="company" name="Company or project" type="text" class={`mt-2 ${field}`} placeholder="Smith & Co." />
          </div>
          <div>
            <label class={labelCls} for="niche">Niche / segment</label>
            <input id="niche" name="Niche" type="text" class={`mt-2 ${field}`} placeholder="e.g. Barber, Restaurant, Law firm" />
          </div>
        </div>
        <div>
          <label class={labelCls} for="city">City / State</label>
          <input id="city" name="City and state" type="text" class={`mt-2 ${field}`} placeholder="e.g. Miami, FL" />
        </div>
      </fieldset>

      <!-- Group: Contact -->
      <fieldset class="space-y-5">
        <legend class="font-display text-lg font-semibold text-ink">Contact</legend>
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class={labelCls} for="email">Email <span class="text-cta-500">*</span></label>
            <input id="email" name="Email" type="email" required class={`mt-2 ${field}`} placeholder="you@example.com" />
            <p class="error-msg mt-1 hidden text-sm text-red-600"></p>
          </div>
          <div>
            <label class={labelCls} for="phone">Phone <span class="text-cta-500">*</span></label>
            <input id="phone" name="Phone" type="tel" required class={`mt-2 ${field}`} placeholder="+1 (xxx) xxx-xxxx" />
            <p class="error-msg mt-1 hidden text-sm text-red-600"></p>
          </div>
        </div>
      </fieldset>

      <!-- Group: About the Project -->
      <fieldset class="space-y-5">
        <legend class="font-display text-lg font-semibold text-ink">About the project</legend>
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class={labelCls} for="hasDomain">Do you already have a domain?</label>
            <select id="hasDomain" name="Has domain" class={`mt-2 ${field} cursor-pointer`}>
              <option value="">Select an option</option>
              <option>Yes, I have a domain</option>
              <option>No, I need one</option>
              <option>Not sure</option>
            </select>
          </div>
          <div>
            <label class={labelCls} for="hasBrand">Do you have a logo and brand colors?</label>
            <select id="hasBrand" name="Has logo and brand" class={`mt-2 ${field} cursor-pointer`}>
              <option value="">Select an option</option>
              <option>Yes, I have both</option>
              <option>I have a logo only</option>
              <option>No, I need help with branding</option>
            </select>
          </div>
        </div>
      </fieldset>

      <!-- Group: Desired Sections / Pages -->
      <fieldset class="space-y-4">
        <legend class="font-display text-lg font-semibold text-ink">Desired sections / pages</legend>
        <p class="text-sm text-muted">Check everything you'd like on your site.</p>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
          {pages.map((page) => (
            <label class="flex cursor-pointer items-center gap-2 rounded-xl border border-brand-200 bg-white px-3 py-2.5 text-sm font-medium text-ink-soft transition-colors hover:border-brand-400 has-[:checked]:border-brand-500 has-[:checked]:bg-brand-50">
              <input type="checkbox" name="Pages" value={page} class="h-4 w-4 rounded border-brand-300 text-brand-600 focus:ring-brand-500 cursor-pointer" />
              {page}
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Group: Your Idea -->
      <fieldset class="space-y-5">
        <legend class="font-display text-lg font-semibold text-ink">Your idea</legend>
        <div>
          <label class={labelCls} for="references">Website references you like</label>
          <input id="references" name="References" type="text" class={`mt-2 ${field}`} placeholder="Paste links to sites you like (comma-separated)" />
        </div>
        <div>
          <label class={labelCls} for="idea">Tell us about your site idea</label>
          <textarea id="idea" name="Site idea" rows="4" class={`mt-2 ${field}`} placeholder="What should your website achieve? Any must-haves, style preferences, or details we should know?"></textarea>
        </div>
      </fieldset>

      <!-- Group: Timeline and Investment -->
      <fieldset class="space-y-5">
        <legend class="font-display text-lg font-semibold text-ink">Timeline and investment</legend>
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class={labelCls} for="timeline">When do you want to launch?</label>
            <select id="timeline" name="Timeline" class={`mt-2 ${field} cursor-pointer`}>
              <option value="">Select a timeline</option>
              <option>As soon as possible</option>
              <option>Within 1–2 weeks</option>
              <option>Within a month</option>
              <option>Just exploring for now</option>
            </select>
          </div>
          <div>
            <label class={labelCls} for="budget">Budget range</label>
            <select id="budget" name="Budget" class={`mt-2 ${field} cursor-pointer`}>
              <option value="">Select a budget</option>
              <option>$199 site only</option>
              <option>$199 + add-ons</option>
              <option>I'd like to discuss options</option>
              <option>Not sure yet</option>
            </select>
          </div>
        </div>
      </fieldset>

      <!-- Consent (TCPA) -->
      <fieldset>
        <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-brand-200 bg-brand-50/50 p-4">
          <input id="consent" name="Consent" type="checkbox" required value="I agree to be contacted" class="mt-0.5 h-5 w-5 shrink-0 rounded border-brand-300 text-brand-600 focus:ring-brand-500 cursor-pointer" />
          <span class="text-sm text-ink-soft">
            I agree to be contacted to receive my free website preview. My data is safe and will not be shared. <span class="text-cta-500">*</span>
          </span>
        </label>
        <p class="error-msg mt-1 hidden text-sm text-red-600"></p>
      </fieldset>

      <div>
        <button
          type="submit"
          id="submit-btn"
          class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-cta-500 px-7 py-4 text-base font-semibold text-white shadow-cta transition-all hover:-translate-y-0.5 hover:bg-cta-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cta-400 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-70 cursor-pointer"
        >
          <span id="submit-label">Get my free preview</span>
          <Icon name="arrow-right" class="h-5 w-5" />
        </button>
        <p class="mt-3 text-center text-xs text-muted">
          Free preview, no commitment. We'll only use your info to deliver your website preview.
        </p>
        <!-- Generic form-level error (network / server) -->
        <p id="form-error" class="mt-3 hidden text-center text-sm text-red-600"></p>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('brief-form') as HTMLFormElement | null;
  if (form) {
    const successBox = document.getElementById('form-success')!;
    const formError = document.getElementById('form-error')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitLabel = document.getElementById('submit-label')!;

    const showError = (input: HTMLElement, message: string) => {
      const msg = input.closest('div, fieldset')?.querySelector('.error-msg') as HTMLElement | null;
      input.classList.add('border-red-400', 'focus:border-red-500', 'focus:ring-red-200');
      if (msg) {
        msg.textContent = message;
        msg.classList.remove('hidden');
      }
    };

    const clearError = (input: HTMLElement) => {
      const msg = input.closest('div, fieldset')?.querySelector('.error-msg') as HTMLElement | null;
      input.classList.remove('border-red-400', 'focus:border-red-500', 'focus:ring-red-200');
      if (msg) msg.classList.add('hidden');
    };

    const validate = () => {
      let ok = true;
      const name = form.querySelector<HTMLInputElement>('#fullName')!;
      const email = form.querySelector<HTMLInputElement>('#email')!;
      const phone = form.querySelector<HTMLInputElement>('#phone')!;
      const consent = form.querySelector<HTMLInputElement>('#consent')!;

      [name, email, phone, consent].forEach(clearError);

      if (!name.value.trim()) { showError(name, 'Please enter your full name.'); ok = false; }
      if (!email.value.trim()) {
        showError(email, 'Please enter your email.'); ok = false;
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value.trim())) {
        showError(email, 'Please enter a valid email address.'); ok = false;
      }
      if (!phone.value.trim()) { showError(phone, 'Please enter your phone number.'); ok = false; }
      if (!consent.checked) { showError(consent, 'Please check the box so we can contact you.'); ok = false; }
      return ok;
    };

    // Clear each field's error as the user fixes it.
    form.querySelectorAll('input, textarea, select').forEach((el) => {
      el.addEventListener('input', () => clearError(el as HTMLElement));
      el.addEventListener('change', () => clearError(el as HTMLElement));
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      formError.classList.add('hidden');
      if (!validate()) {
        form.querySelector('.border-red-400')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      const endpoint = form.getAttribute('action') || '';
      // Guard: endpoint hasn't been configured yet.
      if (endpoint.includes('[FORMSPREE_ENDPOINT]') || !endpoint.startsWith('http')) {
        formError.textContent =
          'Form endpoint not configured yet. Add your Formspree endpoint to the form’s action attribute.';
        formError.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitLabel.textContent = 'Sending…';

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.classList.add('hidden');
          successBox.classList.remove('hidden');
          successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error('Request failed');
        }
      } catch {
        formError.textContent = 'Something went wrong. Please try again, or email us directly.';
        formError.classList.remove('hidden');
        submitBtn.disabled = false;
        submitLabel.textContent = 'Get my free preview';
      }
    });
  }
</script>
