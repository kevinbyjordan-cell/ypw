---
import Icon from './Icon.astro';
import SitePreview from './SitePreview.astro';
import SiteTemplate from './SiteTemplate.astro';

// Signature section: show, don't tell. A full featured template + more examples.
const featuredIncludes = [
  'Custom hero with a clear headline & call-to-action',
  'Service cards that explain what you offer',
  'Photo gallery to show off your work',
  'Mobile-ready nav and one-tap contact',
];

const examples = [
  {
    image: '/showcase/restaurant.webp',
    alt: 'Example restaurant website',
    brand: 'Olive & Ember',
    niche: 'Restaurant',
    nav: ['Menu', 'Reserve', 'About', 'Contact'],
    headline: 'Fresh plates, warm nights.',
    cta: 'Reserve a table',
    accent: '#e2603f',
  },
  {
    image: '/showcase/fitness.webp',
    alt: 'Example fitness studio website',
    brand: 'Forge Fitness',
    niche: 'Personal training',
    nav: ['Programs', 'Coaches', 'Pricing', 'Contact'],
    headline: 'Train with the best.',
    cta: 'Start today',
    accent: '#22c55e',
  },
  {
    image: '/showcase/clinic.webp',
    alt: 'Example dental clinic website',
    brand: 'Bright Smile Dental',
    niche: 'Clinic',
    nav: ['Services', 'Team', 'Insurance', 'Contact'],
    headline: 'Care that feels effortless.',
    cta: 'Request an appointment',
    accent: '#06b6d4',
  },
];
---
<section id="showcase" class="relative overflow-hidden bg-ink py-20 sm:py-28">
  <div class="absolute inset-0 bg-grid opacity-60" aria-hidden="true"></div>
  <div class="pointer-events-none absolute left-1/2 top-0 h-80 w-[40rem] -translate-x-1/2 rounded-full bg-brand-500/15 blur-[120px]" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center reveal">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-sm font-medium text-brand-100">
        <Icon name="palette" class="h-4 w-4 text-cyan-glow" />
        See what you'll get
      </span>
      <h2 class="mt-5 font-display text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
        Real, professional sites — <span class="text-gradient">all for $199</span>
      </h2>
      <p class="mt-4 text-lg text-slate-300">
        This is the level of website we build for local businesses like yours. Custom design,
        mobile-ready, and ready to win customers — no template look, no agency price tag.
      </p>
    </div>

    <!-- Featured full template -->
    <div class="mt-14 grid items-center gap-10 lg:grid-cols-[1fr_0.9fr]">
      <figure class="reveal group">
        <div class="tilt-card" data-tilt>
          <SiteTemplate
            image="/showcase/barber-template.webp"
            alt="A complete barbershop website designed by YPW"
            url="thegroomsmanbarber.com"
          />
        </div>
      </figure>

      <div class="reveal">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/5 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-cyan-glow">
          Barbershop · full website
        </span>
        <h3 class="mt-4 font-display text-2xl font-bold text-white sm:text-3xl">
          A complete site, not a one-pager
        </h3>
        <p class="mt-3 text-slate-300">
          Every site is custom-designed for the business — with real structure that turns
          visitors into customers. Here's what's built in:
        </p>
        <ul class="mt-5 space-y-3">
          {featuredIncludes.map((item) => (
            <li class="flex items-start gap-3 text-slate-200">
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-cyan-glow/15 text-cyan-glow">
                <Icon name="check" class="h-3.5 w-3.5" />
              </span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-7">
          <a
            href="#brief"
            class="group inline-flex items-center justify-center gap-2 rounded-full bg-cta-500 px-7 py-3.5 text-base font-semibold text-white shadow-cta transition-all hover:-translate-y-0.5 hover:bg-cta-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cta-400 focus-visible:ring-offset-2 focus-visible:ring-offset-ink cursor-pointer"
          >
            I want a site like this
            <Icon name="arrow-right" class="h-5 w-5 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
      </div>
    </div>

    <!-- More examples across niches -->
    <p class="mt-16 text-center text-sm font-semibold uppercase tracking-widest text-slate-400 reveal">
      More examples across industries
    </p>
    <div class="mt-7 grid gap-7 sm:grid-cols-2 lg:grid-cols-3">
      {examples.map((ex) => (
        <figure class="reveal group">
          <div class="tilt-card" data-tilt>
            <SitePreview
              image={ex.image}
              alt={ex.alt}
              brand={ex.brand}
              nav={ex.nav}
              headline={ex.headline}
              cta={ex.cta}
              accent={ex.accent}
            />
          </div>
          <figcaption class="mt-4 flex items-center justify-between px-1">
            <div>
              <p class="font-display text-base font-semibold text-white">{ex.brand}</p>
              <p class="text-sm text-slate-400">{ex.niche}</p>
            </div>
            <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-sm font-semibold text-cyan-glow">$199</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-slate-400 reveal">
      Example concepts that reflect the quality and style we deliver for each industry.
    </p>
  </div>
</section>

<script>
  // Pointer tilt on showcase cards (transform only, desktop + fine pointer).
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce && window.matchMedia('(pointer:fine)').matches) {
    document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width - 0.5;
        const py = (e.clientY - r.top) / r.height - 0.5;
        card.style.transform = `perspective(1100px) rotateY(${px * 5}deg) rotateX(${-py * 5}deg) scale(1.01)`;
      });
      card.addEventListener('mouseleave', () => { card.style.transform = ''; });
    });
  }
</script>
