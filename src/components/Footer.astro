---
import Icon from './Icon.astro';

// TODO (CAN-SPAM): when available, add physical mailing address + a link to
// the Privacy Policy page. Both are required for compliant email outreach.
const CONTACT_EMAIL = 'contact@yourprofessionalsite.com';
const CONTACT_PHONE = '+1 (650) 619-7810';
const CONTACT_PHONE_HREF = 'tel:+16506197810';
const year = new Date().getFullYear();
---
<footer class="border-t border-white/10 bg-ink text-brand-50">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <div class="flex items-center gap-2">
          <img src="/ypw-logo.png" alt="YPW Sites logo" width="40" height="40" class="h-9 w-auto" />
          <span class="font-display text-lg font-semibold text-white">YPW · Your Professional Website</span>
        </div>
        <p class="mt-4 max-w-xs text-sm text-brand-100/80">
          Professional websites for small businesses across the United States.
          See your site before you pay — published for a flat $199.
        </p>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-wide text-white">Contact</h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <a href={`mailto:${CONTACT_EMAIL}`} class="inline-flex items-center gap-2 text-brand-100/90 transition-colors hover:text-white">
              <Icon name="mail" class="h-4 w-4" />
              {CONTACT_EMAIL}
            </a>
          </li>
          <li>
            <a href={CONTACT_PHONE_HREF} class="inline-flex items-center gap-2 text-brand-100/90 transition-colors hover:text-white">
              <Icon name="phone" class="h-4 w-4" />
              {CONTACT_PHONE}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold uppercase tracking-wide text-white">Explore</h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li><a href="#showcase" class="text-brand-100/90 transition-colors hover:text-white">Examples</a></li>
          <li><a href="#what-you-get" class="text-brand-100/90 transition-colors hover:text-white">What you get</a></li>
          <li><a href="#how-it-works" class="text-brand-100/90 transition-colors hover:text-white">How it works</a></li>
          <li><a href="#pricing" class="text-brand-100/90 transition-colors hover:text-white">Pricing</a></li>
          <li><a href="#brief" class="text-brand-100/90 transition-colors hover:text-white">Get my free preview</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-6 text-xs text-brand-100/70 sm:flex-row sm:items-center">
      <p>© {year} YPW Sites. All rights reserved.</p>
      <!-- TODO (CAN-SPAM / CCPA): add Privacy Policy link + physical address here. -->
      <p>Serving small businesses across the United States.</p>
    </div>
  </div>
</footer>
