---
import Icon from './Icon.astro';
// Floating contact / conversion button — visible on every scroll position.
---
<a
  href="#brief"
  class="fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 rounded-full bg-cta-500 px-5 py-3.5 font-semibold text-white shadow-cta transition-all hover:-translate-y-0.5 hover:bg-cta-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cta-400 focus-visible:ring-offset-2 cursor-pointer"
  aria-label="Get my free website preview"
>
  <Icon name="message-circle" class="h-5 w-5" />
  <span class="hidden sm:inline">Free preview</span>
</a>
