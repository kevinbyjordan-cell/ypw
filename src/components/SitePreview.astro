---
// A realistic "website inside a browser frame" mockup. Reused in the hero and
// the Showcase so visitors literally see the kind of site they'd get.
interface Props {
  image: string;
  alt: string;
  brand: string;
  nav?: string[];
  headline: string;
  cta: string;
  accent?: string; // hex for the mini-site's accent button
  eager?: boolean; // load image eagerly (use for above-the-fold hero)
  class?: string;
}
const {
  image,
  alt,
  brand,
  nav = ['Home', 'Services', 'About', 'Contact'],
  headline,
  cta,
  accent = '#f97316',
  eager = false,
  class: className = '',
} = Astro.props;
---
<div class={`overflow-hidden rounded-2xl bg-white shadow-float ring-1 ring-black/5 ${className}`}>
  <!-- Browser chrome -->
  <div class="flex items-center gap-2 border-b border-slate-200 bg-slate-100 px-3 py-2.5">
    <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
    <span class="ml-3 hidden flex-1 truncate rounded-md bg-white px-3 py-1 text-[11px] text-slate-400 sm:block">
      {brand.toLowerCase().replace(/\s+/g, '')}.com
    </span>
  </div>

  <!-- Mini website -->
  <div class="relative">
    <!-- Top nav -->
    <div class="absolute inset-x-0 top-0 z-10 flex items-center justify-between px-4 py-3">
      <span class="font-display text-sm font-bold text-white drop-shadow">{brand}</span>
      <div class="hidden items-center gap-3 sm:flex">
        {nav.map((item) => (
          <span class="text-[11px] font-medium text-white/85 drop-shadow">{item}</span>
        ))}
        <span class="rounded-full px-2.5 py-1 text-[11px] font-semibold text-white" style={`background:${accent}`}>Book</span>
      </div>
    </div>

    <!-- Hero image + overlay -->
    <div class="relative aspect-[16/10]">
      <img src={image} alt={alt} class="h-full w-full object-cover" loading={eager ? 'eager' : 'lazy'} fetchpriority={eager ? 'high' : 'auto'} decoding="async" width="1376" height="768" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/25 to-black/30"></div>
      <div class="absolute bottom-0 left-0 max-w-[80%] p-4 sm:p-5">
        <h3 class="font-display text-base font-bold leading-tight text-white drop-shadow-md sm:text-xl">{headline}</h3>
        <span class="mt-3 inline-flex items-center rounded-lg px-3 py-1.5 text-[11px] font-semibold text-white shadow-lg sm:text-xs" style={`background:${accent}`}>
          {cta}
        </span>
      </div>
    </div>

    <!-- Faux content strip (sells "complete site") -->
    <div class="grid grid-cols-3 gap-2 bg-white p-3 sm:gap-3 sm:p-4">
      {[0, 1, 2].map(() => (
        <div class="space-y-1.5 rounded-lg border border-slate-100 p-2">
          <div class="h-1.5 w-8 rounded-full" style={`background:${accent}`}></div>
          <div class="h-1 w-full rounded-full bg-slate-200"></div>
          <div class="h-1 w-3/4 rounded-full bg-slate-100"></div>
        </div>
      ))}
    </div>
  </div>
</div>
