---
import Icon from './Icon.astro';

const items = [
  { icon: 'palette', title: 'Custom design', body: 'A unique look built around your brand and industry — never a generic template.', span: 'lg:col-span-3' },
  { icon: 'smartphone', title: 'Perfect mobile version', body: 'Flawless on phones, where most local customers find you first.', span: 'lg:col-span-3' },
  { icon: 'layers', title: 'Essential pages', body: 'Home, About, Services, and Contact — all you need to win customers.', span: 'lg:col-span-2' },
  { icon: 'message-circle', title: 'Contact integration', body: 'A floating button so customers reach you in one tap.', span: 'lg:col-span-2' },
  { icon: 'clipboard-list', title: 'Lead capture form', body: 'New inquiries land straight in your inbox.', span: 'lg:col-span-2' },
  { icon: 'search', title: 'Basic SEO', body: 'Clean structure, meta tags, and local keywords so customers can find you on Google.', span: 'lg:col-span-3' },
  { icon: 'zap', title: 'Fast performance', body: 'Lightweight, optimized pages that load quickly and keep visitors from leaving.', span: 'lg:col-span-3' },
];
---
<section id="what-you-get" class="bg-paper-tint py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center reveal">
      <span class="text-sm font-semibold uppercase tracking-widest text-brand-600">Everything included</span>
      <h2 class="mt-3 font-display text-3xl font-extrabold text-text sm:text-4xl lg:text-5xl">What you receive</h2>
      <p class="mt-4 text-lg text-muted">
        A complete, professional website with everything a small business needs to look great
        and win customers online — all in your $199 site.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-6">
      {items.map((item) => (
        <div class={`reveal group flex flex-col rounded-2xl border border-slate-200 bg-white p-7 shadow-card transition-all hover:-translate-y-1 hover:border-brand-300 hover:shadow-glow ${item.span}`}>
          <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600 transition-colors group-hover:bg-gradient-to-br group-hover:from-brand-500 group-hover:to-indigo-glow group-hover:text-white">
            <Icon name={item.icon} class="h-6 w-6" />
          </span>
          <h3 class="mt-5 text-lg font-semibold text-text">{item.title}</h3>
          <p class="mt-2 text-muted">{item.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
