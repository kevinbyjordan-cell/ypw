---
// Full-page website template shown inside a browser frame. The image already
// contains a complete site design (nav, hero, sections), so we just frame it.
interface Props {
  image: string;
  alt: string;
  url: string;
  class?: string;
}
const { image, alt, url, class: className = '' } = Astro.props;
---
<div class={`overflow-hidden rounded-2xl bg-white shadow-float ring-1 ring-black/5 ${className}`}>
  <div class="flex items-center gap-2 border-b border-slate-200 bg-slate-100 px-3 py-2.5">
    <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
    <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
    <span class="ml-3 hidden flex-1 truncate rounded-md bg-white px-3 py-1 text-[11px] text-slate-400 sm:block">{url}</span>
  </div>
  <img src={image} alt={alt} class="block w-full" loading="lazy" decoding="async" />
</div>
