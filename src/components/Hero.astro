---
import Icon from './Icon.astro';
import SitePreview from './SitePreview.astro';

const proof = ['Custom design', '100% responsive', 'Basic SEO', 'Lead capture form'];
---
<section id="top" class="relative overflow-hidden bg-ink pt-28 pb-20 sm:pt-32 lg:pt-36 lg:pb-28">
  <!-- Atmosphere: grid + gradient glows -->
  <div class="absolute inset-0 bg-grid" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -top-32 left-1/4 h-[32rem] w-[32rem] -translate-x-1/2 rounded-full bg-indigo-glow/25 blur-[120px]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -right-20 top-20 h-96 w-96 rounded-full bg-cyan-glow/15 blur-[120px]" aria-hidden="true"></div>
  <div class="pointer-events-none absolute bottom-0 left-0 h-72 w-72 rounded-full bg-cta-500/10 blur-[100px]" aria-hidden="true"></div>

  <div class="relative mx-auto grid max-w-6xl items-center gap-14 px-4 sm:px-6 lg:grid-cols-[1.05fr_1fr]">
    <!-- Copy -->
    <div class="text-center lg:text-left">
      <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-sm font-medium text-brand-100 backdrop-blur">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-cyan-glow opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-cyan-glow"></span>
        </span>
        Free preview in 24–48h · no commitment
      </span>

      <h1 class="mt-6 font-display text-4xl font-extrabold leading-[1.05] text-white sm:text-5xl lg:text-6xl">
        An incredible website
        <span class="text-gradient">for your business</span>
        — see it before you pay.
      </h1>

      <p class="mx-auto mt-6 max-w-xl text-lg text-slate-300 lg:mx-0">
        We design and build your complete, professional site first. You get a free
        preview in 24–48 hours. Love it? We publish it for a flat
        <span class="font-semibold text-white">$199</span>. If you don't, you pay nothing.
      </p>

      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center lg:justify-start">
        <a
          href="#brief"
          class="group inline-flex w-full items-center justify-center gap-2 rounded-full bg-cta-500 px-7 py-4 text-base font-semibold text-white shadow-cta transition-all hover:-translate-y-0.5 hover:bg-cta-600 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-cta-400 focus-visible:ring-offset-2 focus-visible:ring-offset-ink sm:w-auto cursor-pointer"
        >
          Get my free preview
          <Icon name="arrow-right" class="h-5 w-5 transition-transform group-hover:translate-x-1" />
        </a>
        <a
          href="#showcase"
          class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-white/20 bg-white/5 px-7 py-4 text-base font-semibold text-white backdrop-blur transition-colors hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40 sm:w-auto cursor-pointer"
        >
          See real examples
        </a>
      </div>

      <!-- Price + proof row -->
      <div class="mt-9 flex flex-col items-center gap-5 sm:flex-row sm:items-center lg:justify-start">
        <div class="flex items-baseline gap-2">
          <span class="font-display text-3xl font-extrabold text-white">$199</span>
          <span class="text-sm text-slate-400">flat to publish</span>
        </div>
        <span class="hidden h-8 w-px bg-white/15 sm:block"></span>
        <ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2">
          {proof.map((p) => (
            <li class="flex items-center gap-1.5 text-sm text-slate-300">
              <Icon name="check" class="h-4 w-4 text-cyan-glow" />
              {p}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Visual: floating site preview cluster -->
    <div class="relative mx-auto w-full max-w-lg" id="hero-cluster">
      <div class="pointer-events-none absolute -inset-6 rounded-[2rem] bg-gradient-to-tr from-brand-500/30 via-indigo-glow/20 to-cyan-glow/30 blur-2xl" aria-hidden="true"></div>

      <!-- Desktop preview (parallax wrapper + float inner — separate transforms) -->
      <div data-parallax="0.04">
        <div class="relative animate-floaty">
          <SitePreview
            image="/showcase/barber.webp"
            alt="Example barbershop website built by YPW"
            brand="Ironside Barber"
            nav={['Home', 'Services', 'Team', 'Contact']}
            headline="Sharp cuts. Classic service."
            cta="Book your chair"
            accent="#d99a3f"
            eager
          />
        </div>
      </div>

      <!-- Phone preview overlapping -->
      <div class="absolute -bottom-10 -left-6 w-32 sm:w-40" data-parallax="0.09" aria-hidden="true">
        <div class="animate-floaty-slow overflow-hidden rounded-[1.5rem] border-4 border-ink-3 bg-white shadow-float ring-1 ring-white/10">
          <div class="relative aspect-[9/16]">
            <img src="/showcase/fitness.webp" alt="" class="h-full w-full object-cover" loading="eager" decoding="async" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-black/10"></div>
            <div class="absolute bottom-0 p-3">
              <p class="font-display text-xs font-bold leading-tight text-white">Train with the best</p>
              <span class="mt-2 inline-block rounded-md bg-[#22c55e] px-2 py-1 text-[10px] font-semibold text-white">Start today</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating "$199" badge -->
      <div class="absolute -right-3 top-8 rotate-3 rounded-2xl border border-white/15 bg-white/95 px-4 py-2.5 shadow-float backdrop-blur sm:-right-6">
        <p class="text-[10px] font-medium uppercase tracking-wide text-muted">Published for</p>
        <p class="font-display text-xl font-extrabold text-ink">$199</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Subtle mouse parallax on the hero cluster (transform only).
  const cluster = document.getElementById('hero-cluster');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (cluster && !reduce && window.matchMedia('(pointer:fine)').matches) {
    const layers = cluster.querySelectorAll<HTMLElement>('[data-parallax]');
    window.addEventListener('mousemove', (e) => {
      const x = (e.clientX / window.innerWidth - 0.5) * 2;
      const y = (e.clientY / window.innerHeight - 0.5) * 2;
      layers.forEach((el) => {
        const depth = parseFloat(el.dataset.parallax || '0') * 40;
        el.style.transform = `translate3d(${x * depth}px, ${y * depth}px, 0)`;
      });
    }, { passive: true });
  }
</script>
