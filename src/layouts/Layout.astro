---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'YPW Sites — Professional Websites for Small Businesses | Free Preview, $199',
  description = 'See your professional website before you pay. Free preview in 24–48 hours, no commitment. Publish for a flat $199 — modern design, mobile-ready, basic SEO.',
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;

// LocalBusiness-style schema (English, US market). Update NAP when available.
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'YPW — Your Professional Website',
  description,
  areaServed: 'United States',
  priceRange: '$199',
  email: 'contact@yourprofessionalsite.com',
  telephone: '+1-650-619-7810',
  url: Astro.site?.toString() ?? canonical,
  makesOffer: {
    '@type': 'Offer',
    name: 'Professional small-business website',
    price: '199',
    priceCurrency: 'USD',
    description: 'Free website preview in 24–48 hours. Publish for a flat $199.',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/ypw-logo.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/ypw-logo.png" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fonts: Sora (display) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="bg-white text-ink-soft">
    <slot />

    <!-- Reveal-on-scroll: progressive enhancement, respects reduced motion -->
    <script>
      const els = document.querySelectorAll('.reveal');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
